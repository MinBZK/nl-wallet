{
  "vct": "urn:eudi:pid:nl:1",
  "name": "NL PID credential",
  "description": "Working version of the Dutch PID credential",
  "extends": "urn:eudi:pid:1",
  "extends#integrity": "sha256-1VIdCfQ/u2v814A0tcoSGC4BEf0ojkPb+d8i0Lu8A4o=",
  "display": [
    {
      "lang": "en-US",
      "name": "Personal data",
