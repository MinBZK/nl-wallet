<!doctype html>
<html lang="nl">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1" />
        <title>NL Wallet — kies een test-identiteit</title>
        <style>
            :root {
                color-scheme: light dark;
                --bg: #f3f4f6;
                --card-bg: #ffffff;
                --border: #d0d5dd;
                --accent: #154273; /* Rijksoverheid blue */
                --text: #1f2933;
                --muted: #667085;
            }
            @media (prefers-color-scheme: dark) {
                :root {
                    --bg: #1f2933;
                    --card-bg: #27313d;
                    --border: #3b4756;
                    --accent: #8fb8e0;
                    --text: #f3f4f6;
                    --muted: #9aa5b1;
                }
            }
            * {
                box-sizing: border-box;
            }
            body {
                margin: 0;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 2rem;
                padding: 2rem 1rem;
                background: var(--bg);
                color: var(--text);
                font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            }
            h1 {
                margin: 0;
                font-size: 1.5rem;
                text-align: center;
            }
            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
                gap: 1rem;
                width: 100%;
                max-width: 720px;
            }
            .card {
                display: flex;
                flex-direction: column;
                gap: 0.35rem;
                padding: 1.1rem 1.25rem;
                border: 1px solid var(--border);
                border-radius: 12px;
                background: var(--card-bg);
                text-decoration: none;
                color: inherit;
                transition: border-color 0.15s ease, transform 0.1s ease;
            }
            .card:hover,
            .card:focus-visible {
                border-color: var(--accent);
                transform: translateY(-2px);
                outline: none;
            }
            .card .name {
                font-size: 1.1rem;
                font-weight: 600;
            }
            .card .bsn {
                font-size: 0.85rem;
                color: var(--muted);
                font-variant-numeric: tabular-nums;
            }
            .empty {
                color: var(--muted);
            }
        </style>
    </head>
    <body>
        <h1>Kies een test-identiteit</h1>
        {% if cards.is_empty() %}
        <p class="empty">Geen test-identiteiten geconfigureerd.</p>
        {% else %}
        <div class="grid">
            {% for card in cards %}
            <a class="card" href="{{ card.href }}">
                <span class="name">{{ card.name }}</span>
                <span class="bsn">BSN {{ card.bsn }}</span>
            </a>
            {% endfor %}
        </div>
        {% endif %}
    </body>
</html>
