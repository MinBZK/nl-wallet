{
  "vct": "com.example.address",
  "name": "NL Wallet address credential",
  "description": "Working version of the NL Wallet address credential",
  "display": [
    {
      "locale": "en-US",
      "name": "NL Wallet address",
      "description": "The address credential for the NL Wallet"
    },
    {
      "locale": "nl-NL",
      "name": "NL Wallet adres",
      "description": "De adresattestatie voor de NL Wallet"
    }
  ],
  "claims": [
    {
      "path": ["resident_street"],
      "display": [
        {
          "locale": "nl-NL",
          "label": "Straatnaam",
          "description": "Straatnaam van het adres"
        },
        {
          "locale": "en-US",
          "label": "Street",
          "description": "Street of the address"
        }
      ],
      "sd": "always"
    },
    {
      "path": ["resident_house_number"],
      "display": [
        {
          "locale": "nl-NL",
          "label": "Huisnummer",
          "description": "Huisnummer van het adres"
        },
        {
          "locale": "en-US",
          "label": "House number",
          "description": "House number of the address"
        }
      ],
      "sd": "always"
    },
    {
      "path": ["resident_postal_code"],
      "display": [
        {
          "locale": "nl-NL",
          "label": "Postcode",
          "description": "Postcode van het adres"
        },
        {
          "locale": "en-US",
          "label": "Postal code",
          "description": "Postal code of the address"
        }
      ],
      "sd": "always"
    },
    {
      "path": ["resident_city"],
      "display": [
        {
          "locale": "nl-NL",
          "label": "Stad",
          "description": "Stad van het adres"
        },
        {
          "locale": "en-US",
          "label": "City",
          "description": "City of the address"
        }
      ],
      "sd": "always"
    },
    {
      "path": ["resident_country"],
      "display": [
        {
          "locale": "nl-NL",
          "label": "Land",
          "description": "Land van het adres"
        },
        {
          "locale": "en-US",
          "label": "Country",
          "description": "Country of the address"
        }
      ],
      "sd": "always"
    }
  ]
}
