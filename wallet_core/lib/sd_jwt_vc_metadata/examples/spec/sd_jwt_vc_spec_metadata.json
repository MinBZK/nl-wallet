          "background_image": {
            "uri": "https://betelgeuse.example.com/public/credential-background.png",
            "uri#integrity": "sha256-5sBT7mMLylHLWrrS/qQ8aHpRAxoraWVmWX6eUVMlrrA="
          },
          "background_color": "#12107c",
          "text_color": "#FFFFFF"
