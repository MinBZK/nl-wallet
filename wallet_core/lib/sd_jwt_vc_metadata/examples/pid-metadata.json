{
  "vct": "urn:example:pid:nl:1",
  "name": "NL Wallet PID credential",
  "description": "Working version of the NL Wallet PID credential",
  "display": [
    {
      "locale": "en-US",
      "name": "NL Wallet Personal Data",
      "description": "The Personal Data credential for the NL Wallet",
      "summary": "{{first_name}}"
    },
    {
      "locale": "nl-NL",
      "name": "NL Wallet persoonsgegevens",
      "description": "De persoonsgegevensattestatie voor de NL Wallet",
      "summary": "{{first_name}}"
    }
  ],
  "claims": [
    {
      "path": ["family_name"],
      "display": [
        {
          "locale": "nl-NL",
          "label": "Achternaam",
          "description": "Achternaam van de persoon, inclusief voorvoegsels"
        },
        {
          "locale": "en-US",
          "label": "Name",
          "description": "Family name of the person, including any prefixes"
        }
      ],
      "sd": "always",
      "svg_id": "last_name"
    },
    {
      "path": ["given_name"],
      "display": [
        {
          "locale": "nl-NL",
          "label": "Voornaam",
          "description": "Voornaam van de persoon"
        },
        {
          "locale": "en-US",
          "label": "First name",
          "description": "First name of the person"
        }
      ],
      "sd": "always",
      "svg_id": "first_name"
    },
    {
      "path": ["birthdate"],
      "display": [
        {
          "locale": "nl-NL",
          "label": "Geboortedatum",
          "description": "Geboortedatum van de persoon"
        },
        {
          "locale": "en-US",
          "label": "Birth date",
          "description": "Birth date of the person"
        }
      ],
      "sd": "always"
    },
    {
      "path": ["age_over_18"],
      "display": [
        {
          "locale": "nl-NL",
          "label": "18+",
          "description": "Of de persoon 18+ is"
        },
        {
          "locale": "en-US",
          "label": "Over 18",
          "description": "Whether the person is over 18"
        }
      ],
      "sd": "always"
    },
    {
      "path": ["bsn"],
      "display": [
        {
          "locale": "nl-NL",
          "label": "BSN",
          "description": "BSN van de persoon"
        },
        {
          "locale": "en-US",
          "label": "BSN",
          "description": "BSN of the person"
        }
      ],
      "sd": "always",
      "mandatory": true
    },
    {
      "path": ["recovery_code"],
      "display": [
        {
          "locale": "en-US",
          "label": "Recovery code",
          "description": "Recovery code of the person"
        },
        {
          "locale": "nl-NL",
          "label": "Herstelcode",
          "description": "Herstelcode van de persoon"
        }
      ],
      "sd": "always",
      "mandatory": true
    }
  ]
}
